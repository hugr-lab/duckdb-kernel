{
  "name": "hugr-result-renderer",
  "displayName": "HUGR Result Viewer",
  "description": "Result viewer for DuckDB Kernel in VS Code notebooks",
  "version": "0.1.0",
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0"
  },
  "main": "./out/extension.js",
  "activationEvents": [],
  "contributes": {
    "notebookRenderer": [
      {
        "id": "hugr-result-renderer",
        "displayName": "HUGR Result Viewer",
        "entrypoint": "./out/renderer.js",
        "mimeTypes": [
          "application/vnd.hugr.result+json"
        ]
      }
    ]
  },
  "scripts": {
    "build": "node build.mjs"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/vscode-notebook-renderer": "^1.72.0",
    "esbuild": "^0.27.4",
    "typescript": "~5.8.0"
  }
}
