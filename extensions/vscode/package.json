{
  "name": "hugr-result-renderer",
  "displayName": "HUGR Result Viewer",
  "description": "Result viewer and database explorer for DuckDB Kernel in VS Code notebooks",
  "version": "0.2.0",
  "publisher": "hugr-lab",
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/hugr-lab/duckdb-kernel",
    "directory": "extensions/vscode"
  },
  "homepage": "https://hugr-lab.github.io",
  "bugs": {
    "url": "https://github.com/hugr-lab/duckdb-kernel/issues"
  },
  "categories": [
    "Notebooks",
    "Data Science",
    "Visualization"
  ],
  "keywords": [
    "duckdb",
    "sql",
    "notebook",
    "arrow",
    "perspective",
    "database",
    "explorer"
  ],
  "engines": {
    "vscode": "^1.80.0"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onNotebook:*",
    "onView:duckdb.session",
    "onView:duckdb.catalog",
    "onView:duckdb.systemFunctions",
    "onView:duckdb.extensions",
    "onView:duckdb.secrets",
    "onView:duckdb.settings",
    "onView:duckdb.memory",
    "onView:duckdb.resultFiles"
  ],
  "contributes": {
    "notebookRenderer": [
      {
        "id": "hugr-result-renderer",
        "displayName": "HUGR Result Viewer",
        "entrypoint": "./out/renderer.js",
        "mimeTypes": [
          "application/vnd.hugr.result+json"
        ],
        "requiresMessaging": "optional"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "duckdb-explorer",
          "title": "DuckDB Explorer",
          "icon": "media/duckdb-activitybar.svg"
        }
      ]
    },
    "views": {
      "duckdb-explorer": [
        {
          "id": "duckdb.session",
          "name": "Session"
        },
        {
          "id": "duckdb.catalog",
          "name": "Catalog"
        },
        {
          "id": "duckdb.systemFunctions",
          "name": "System Functions"
        },
        {
          "id": "duckdb.extensions",
          "name": "Extensions"
        },
        {
          "id": "duckdb.secrets",
          "name": "Secrets"
        },
        {
          "id": "duckdb.settings",
          "name": "Settings"
        },
        {
          "id": "duckdb.memory",
          "name": "Memory"
        },
        {
          "id": "duckdb.resultFiles",
          "name": "Result Files"
        }
      ]
    },
    "commands": [
      {
        "command": "duckdb.refreshCatalog",
        "title": "Refresh Catalog",
        "icon": "$(refresh)",
        "category": "DuckDB"
      },
      {
        "command": "duckdb.refreshExtensions",
        "title": "Refresh Extensions",
        "icon": "$(refresh)",
        "category": "DuckDB"
      },
      {
        "command": "duckdb.refreshSecrets",
        "title": "Refresh Secrets",
        "icon": "$(refresh)",
        "category": "DuckDB"
      },
      {
        "command": "duckdb.refreshSettings",
        "title": "Refresh Settings",
        "icon": "$(refresh)",
        "category": "DuckDB"
      },
      {
        "command": "duckdb.refreshMemory",
        "title": "Refresh Memory",
        "icon": "$(refresh)",
        "category": "DuckDB"
      },
      {
        "command": "duckdb.refreshResultFiles",
        "title": "Refresh Result Files",
        "icon": "$(refresh)",
        "category": "DuckDB"
      },
      {
        "command": "duckdb.refreshSystemFunctions",
        "title": "Refresh System Functions",
        "icon": "$(refresh)",
        "category": "DuckDB"
      },
      {
        "command": "duckdb.showInfo",
        "title": "Show Info",
        "icon": "$(info)",
        "category": "DuckDB"
      },
      {
        "command": "duckdb.deleteResultFile",
        "title": "Delete Result File",
        "icon": "$(trash)",
        "category": "DuckDB"
      },
      {
        "command": "duckdb.refreshNode",
        "title": "Refresh",
        "icon": "$(refresh)",
        "category": "DuckDB"
      },
      {
        "command": "duckdb.installKernel",
        "title": "Install / Update DuckDB Kernel",
        "icon": "$(cloud-download)",
        "category": "DuckDB"
      },
      {
        "command": "duckdb.openResultInTab",
        "title": "Open Result in Tab",
        "icon": "$(link-external)",
        "category": "DuckDB"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "duckdb.installKernel",
          "when": "view == duckdb.session",
          "group": "navigation"
        },
        {
          "command": "duckdb.refreshCatalog",
          "when": "view == duckdb.catalog",
          "group": "navigation"
        },
        {
          "command": "duckdb.refreshExtensions",
          "when": "view == duckdb.extensions",
          "group": "navigation"
        },
        {
          "command": "duckdb.refreshSecrets",
          "when": "view == duckdb.secrets",
          "group": "navigation"
        },
        {
          "command": "duckdb.refreshSettings",
          "when": "view == duckdb.settings",
          "group": "navigation"
        },
        {
          "command": "duckdb.refreshMemory",
          "when": "view == duckdb.memory",
          "group": "navigation"
        },
        {
          "command": "duckdb.refreshResultFiles",
          "when": "view == duckdb.resultFiles",
          "group": "navigation"
        },
        {
          "command": "duckdb.refreshSystemFunctions",
          "when": "view == duckdb.systemFunctions",
          "group": "navigation"
        }
      ],
      "notebook/cell/title": [
        {
          "command": "duckdb.openResultInTab",
          "when": "notebookCellHasOutputs",
          "group": "inline@10"
        }
      ],
      "view/item/context": [
        {
          "command": "duckdb.refreshNode",
          "when": "viewItem == database || viewItem == schema || viewItem == category",
          "group": "inline@1"
        },
        {
          "command": "duckdb.showInfo",
          "when": "viewItem == table || viewItem == view || viewItem == database || viewItem == secret || viewItem == extension || viewItem == function || viewItem == function_group",
          "group": "inline@2"
        },
        {
          "command": "duckdb.deleteResultFile",
          "when": "viewItem == spool_file",
          "group": "inline@2"
        }
      ]
    }
  },
  "scripts": {
    "build": "node build.mjs",
    "vscode:prepublish": "node build.mjs"
  },
  "devDependencies": {
    "@perspective-dev/client": "^4.3.0",
    "@perspective-dev/server": "^4.3.0",
    "@perspective-dev/viewer": "^4.3.0",
    "@perspective-dev/viewer-d3fc": "^4.3.0",
    "@perspective-dev/viewer-datagrid": "^4.3.0",
    "@types/vscode": "^1.80.0",
    "@types/vscode-notebook-renderer": "^1.72.0",
    "esbuild": "^0.27.4",
    "typescript": "~5.8.0"
  },
  "dependencies": {
    "@deck.gl/core": "^9.2.11",
    "@deck.gl/extensions": "^9.2.11",
    "@deck.gl/geo-layers": "^9.2.11",
    "@deck.gl/layers": "^9.2.11",
    "@deck.gl/mesh-layers": "^9.2.11",
    "@geoarrow/deck.gl-layers": "^0.3.1",
    "@geoarrow/geoarrow-wasm": "^0.2.0-beta.5",
    "apache-arrow": "^21.1.0"
  }
}
